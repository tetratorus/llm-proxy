{
  "outbound": [
    {
      "name": "outbound-api-key-like-secret",
      "pattern": "(sk-[A-Za-z0-9_-]{20,}|(?:OPENAI_API_KEY|ANTHROPIC_API_KEY|DEEPSEEK_API_KEY|GEMINI_API_KEY|XAI_API_KEY|OPENROUTER_API_KEY)\\s*=\\s*[\"']?[^\"'\\s]{12,})",
      "flags": "i",
      "hook_url": "http://127.0.0.1:8888/hooks/policy"
    }
  ],
  "inbound": [
    {
      "name": "inbound-api-key-like-secret",
      "pattern": "(sk-[A-Za-z0-9_-]{20,}|(?:OPENAI_API_KEY|ANTHROPIC_API_KEY|DEEPSEEK_API_KEY|GEMINI_API_KEY|XAI_API_KEY|OPENROUTER_API_KEY)\\s*=\\s*[\"']?[^\"'\\s]{12,})",
      "flags": "i",
      "hook_url": "http://127.0.0.1:8888/hooks/policy"
    },
    {
      "name": "inbound-risky-command-text",
      "pattern": "(rm\\s+-rf|git\\s+push\\s+--force|cat\\s+\\.env|sed\\s+-n.*\\.env)",
      "flags": "i",
      "hook_url": "http://127.0.0.1:8888/hooks/policy"
    }
  ]
}
